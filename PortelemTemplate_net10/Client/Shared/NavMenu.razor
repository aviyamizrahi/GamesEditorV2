                    </svg>

                </button>

            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <div class="navbar-wrapper">
            <div class="navbar-inner">
                <div class="navbar-logo">
                    <img src="Images/Logo.png" alt="איקס מיון" />
                </div>
                <div class="navbar-links">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">למשחק</NavLink>
                    <NavLink class="nav-link" href="./GamesList">למשחקים שלי</NavLink>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

