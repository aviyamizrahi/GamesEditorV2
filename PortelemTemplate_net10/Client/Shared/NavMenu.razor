@inject IAuthenticationService _Auth

<AuthorizeView>
    <Authorized>
        <div class="navbar-wrapper">
            <div class="navbar-inner">
  
                @* לוגו + שם אפליקציה *@
                <div class="navbar-logo">
                    <img src="Images/Logo.png" alt="איקס מיון" />
                </div>

                @* שם המשתמש *@
                @if (user != null)
                {
                    <div class="navbar-divider"></div>
                    <span class="navbar-username">@user.FirstName @user.LastName</span>
                }

                @* ניווט *@
                <div class="navbar-links">
                    <NavLink class="nav-link" href="game" Match="NavLinkMatch.All">למשחק</NavLink>
                    <NavLink class="nav-link" href="./GamesList">למשחקים שלי</NavLink>
                    <button class="nav-link nav-link-btn" 
                            @onclick="() => showHowToPlayPopup = true">איך משחקים</button>
                    <button class="nav-link nav-link-btn"
                            @onclick="() => showHowOdotPopup = true">אודות</button>
                </div>

                @* התנתקות *@
                <div class="navbar-divider"></div>
                <button class="navbar-logout" @onclick="() => { _Auth.Logout(); }">התנתקות
                    <svg aria-label="אייקון התנתקות" width="18" height="16" viewBox="0 0 22 20" fill="none" xmlns="http://www.w3.org/2000/svg">
