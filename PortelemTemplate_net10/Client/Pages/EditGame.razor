@page "/EditGame/{gameIdToEdit:int}"
@attribute [Authorize]
@using AuthTemplate.Shared.CheckDTOs
@using AuthTemplate.Shared.Games
@using AuthTemplate.Shared.EditGameContentDTOs
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS


<PageTitle>עריכת משחק - איקס מיון</PageTitle>


<style>
    .selected-category {
        border: 2px solid blue;
        background-color: #f0f4ff;
    }
</style>

<div class="head-of-page">
    @if (String.IsNullOrWhiteSpace(displayName))
    {
        <h1>עריכת משחק</h1>
    }
    else
    {
        <h1>עריכת משחק ״@displayName״</h1>
    }
    <div class="btns-wrapper">
        @if (gameStatus.IsPublish)
        {
            <Button Variant="primary" Text="ביטול פרסום" OnClick="UnpublishGame"></Button>
        }
        else
        {
            <Tooltip Text="@(!gameStatus.CanPublish ? "המשחק לא עומד בתנאי הפרסום" : "")" MaxWidth="200">
                <Button Variant="primary" Text="פרסום משחק" OnClick="() => showPublishPopup = true"
                        Disabled="@(!gameStatus.CanPublish || contentChanged || canSave)">
                </Button>
            </Tooltip>
        }

        <Button Variant="secondery" Text="חזרה למשחקים שלי" OnClick="HandleBackNavigation"></Button>
        @* הכפתור יהיה פעיל רק במידה ומשחק חדש נשמר ויש לו מספר id בבסיס הנתונים *@

    </div>
</div>


@* ──────────────── הגדרות משחק ───────────────── *@

<AccordionSection Title="הגדרות כלליות" IsOpen="@isSettingsOpen" UnsavedChanges="@canSave">
    <HeaderButtons>
        <div class="btns-wrapper">
            <Button Type="submit"
                    Text="שמירה"
                    Variant="primary"
                    Form="settings-form"
                    Disabled="@(!canSave)"/>
            <Button Text="ביטול שינויים"
                    Variant="secondery"
                    Disabled="@(!canSave || gameToEdit.ID == 0)"
                    OnClick="CancelChanges"/>
        </div>
        
    </HeaderButtons>
    <ChildContent>
        <div class="settings-content">
            <EditForm Model="gameToEdit" OnValidSubmit="SaveGameSettings" id="settings-form">
                <DataAnnotationsValidator/>
                <div class="settings-right">
                    <div>
                        <label>
                            <span class="input-name">שם המשחק:</span>
                            <CustomInputText @bind-Value="gameToEdit.GameName"
                                             placeholder="שם משחק..."
                                             minLength="1"
                                             maxLength="40"
                                             @bind-Value:after="CheckCanSave"/>
                        </label>
                        <ValidationMessage For="@(() => gameToEdit.GameName)"/>
                    </div>
                    <br/>
                    <div>
                        @* לא ניתן היה לשלוט בחיצים של תיבת מספר רגילה לכן בנינו כפתורים שמדמים את החיצים והסרנו את החיצים מהתיבת מספר *@
                        <label class="input-name">זמן למיון פריט בכל תור</label>
                        <div class="time-section-wrapper">
                            <div class="number-input-wrapper @(noLimit ? "disabled" : "")">
                                <div class="number-arrows">
                                    <button type="button"
                                            @onclick="() => { if (gameToEdit.RoundTime < 60) { gameToEdit.RoundTime += 5; CheckCanSave(); } }"
                                            disabled="@(gameToEdit.RoundTime >= 60 || noLimit)">
                                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M7 14L12 9L17 14" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                    <button type="button"
                                            @onclick="() => { if (gameToEdit.RoundTime > 20) { gameToEdit.RoundTime -= 5; CheckCanSave(); } }"
                                            disabled="@(gameToEdit.RoundTime <= 20 || noLimit)">
                                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M7 10L12 15L17 10" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                </div>
                                <InputNumber @bind-Value="gameToEdit.RoundTime"
                                             step="5"
                                             min="20"
                                             max="60"
                                             disabled="@noLimit"
                                             @bind-Value:after="CheckCanSave"/>
                            </div>
                            <b> או </b>
                            <label>
                                <InputCheckbox class="settings-checkbox" @bind-Value="noLimit" @bind-Value:after="OnNoLimitAndCheckSave"/>
                                ללא הגבלה
                            </label>
                        </div>

                    </div>
                    <br/>
                </div>
                
                <div class="settings-left">
                    <div>
                        <label>
                            <span class="input-name">הנחיות העורך:</span>
                            <CustomInputTextArea @bind-Value="gameToEdit.Instructions"
                                                 placeholder="כתבו הנחיה משלכם"
                                                 minLength="1"
                                                 maxLength="55"
                                                 @bind-Value:after="CheckCanSave"/>
                        </label>
                    </div>
                    <ValidationMessage For="@(() => gameToEdit.Instructions)"/>
                    <p class="msg">@msg</p>
                </div>
            </EditForm>
        </div>
        
    </ChildContent>
</AccordionSection>


@* ───────────── עריכת התוכן ───────────────── *@

<AccordionSection Title="עריכת תוכן" Disabled="@(gameToEdit.ID == 0)" UnsavedChanges="@contentChanged" AdditionalClass="edit-content">
    <HeaderButtons>
        <div class="btns-wrapper">
            <div class="publish-conditions">
            <span>
                @if (hasMinCategories)
                {
