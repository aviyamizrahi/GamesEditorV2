    void MarkContentChanged()
    // המטרה: להגיד שיש שינוי בעריכת התוכן וגם לנקות את התיבה
    {
        contentChanged = true;;
        contentMsg = "";
        CheckHasItemsInEmptyCategory(); // בודקת אם יש פריטים בעלי תוכן בתוך קטגוריה ריקה
        CalcStats(); // אם יש שינוי בתוכן כנראה שצריך לעדכן את לוח הסבבים
        
    }
    
    void CheckHasItemsInEmptyCategory()
        // מטרפת הפונקציה היא לבדוק האם יש פריטים בעלי תוכן בתוך קטגוריה שהיא ריקה
        // לא ניתן למשתמש לשמור את התוכן במקרה כזה
    {
        catsIdsWithItemsEmptyContent = new List<int>(); // איפוס של הרשימה
        hasItemsInEmptyCategory = false; // איפוס
        foreach (var cat in categories) // מעבר על הקטגוריות
        {
            if (string.IsNullOrWhiteSpace(cat.Content)) // אם הקטגוריה ריקה מתוכן
            {
                foreach (ItemToSave item in cat.Items) // מעבר על הפריטים בתוך הקטגוריה
                {
                    if (!string.IsNullOrWhiteSpace(item.Content)) // אם יש בפריטים תוכן
                    {
                        hasItemsInEmptyCategory = true; // המשתנה חיובי
                        catsIdsWithItemsEmptyContent.Add(cat.ID); // תוסיף את מספר הid של הקטגוריה לרשימה של הקטגוריות הריקות
                    }
                }
            }
        }
    }
    
    void CalcStats()
    // מטרת הפונקציה: לחשב את מספר הפריטים הקיימים כדי לתת אינדיקציה בזמן אמת למשתמש על כמות הסבבים שיהיו לו במשחק עצמו
    {
        // איפוס משתנים
        totalItems = 0;
        showBoard = false;

        foreach (CategoryToSave cat in categories) // מעבר על כל הקטגוריות
        {
            if (!string.IsNullOrWhiteSpace(cat.Content)) // בדיקה שיש תוכן בלפחות קטגוריה אחת
                showBoard = true; // אם יש תוכן בקטגוריה אפשר כבר להראות את הלוח גם אם אין עדיין פריטים

            if (cat.Items != null) // ספרית כל הפריטים
            {
                foreach (ItemToSave item in cat.Items) // ספירה של כל הפריטים הקיימים בעלי תוכן
                {
                    if (!string.IsNullOrWhiteSpace(item.Content))
                        totalItems++; // משתנה שסוכם כדי שנוכל להציג
                }
            }
        }

        if (gameStatus.CanPublish) // רק אם המשתמש יכול לפרסם זה אומר שיש בכלל מינימום פריטים למשחק לכן צריך להתחיל לחשב סבבים רק אם הגענו בכלל למינימום
        {
        rounds = totalItems / 9; // כל סבב במשחק מורכב מכמות הפריטים בסה״כ חלקי 9 ועיגול כלפי מטה
        // חקירה עצמית: חלוקה של int בint תחזיר תמיד תוצאה מעוגלת כלפי מטה

        // חישוב של כמה פריטים חסרים כדי להשלים לסבב נוסף (שארית חלוקה)
        if (totalItems % 9 != 0)
        missingItems = 9 - (totalItems % 9);
        else
        missingItems = 0;
        }
    }

    // ── שמירת תוכן ── //
    async Task SaveContent()
    // מטרתה של הפונקציה היא:
    // 1. לבדוק שהתוכן שהוזן נכון 
    // 2. לשלוח את המופע - משחק שלם שמכיל את כל השינויים שהמשתמש עשה
    //3. טוען את התוכן חזרה מהשרת כדי לעדכן קטגוריות / פריטים שהתווספו
    // 4. בדיקת מצב הפרסום
    {
         // לפני שליחה לשרת נרצה לנקות את כל הקטגוריות / פריטים הריקים + לנקות רווחים מיותרים
        await CleanContentBeforeSave();

        
        FullGameToSave fullGame = new FullGameToSave
        {
            Categories = categories,
            DeletedCategoryIds = deletedCategoryIds,
            DeletedItemIds = deletedItemIds
        };

        var res = await Http.PostAsJsonAsync($"api/EditGame/SaveContent/{gameToEdit.ID}", fullGame);
        if (res.IsSuccessStatusCode)
        {
            // מחיקת תמונות שהוסרו
            if (deletedImagePaths.Count > 0)
            {
                await Http.PostAsJsonAsync("api/Media/deleteImages", deletedImagePaths);
                deletedImagePaths = new List<string>(); // איפוס הרשימה של התמונות למחיקה
            }
            contentMsg = "השינויים נשמרו בהצלחה";
            contentChanged = false;
            // איפוס רשימות המחיקה לאחר שמירה מוצלחת
            deletedCategoryIds = new List<int>();
            deletedItemIds = new List<int>();
            // טעינה מחדש מהשרת כדי לקבל IDים מעודכנים
            await LoadGameContent();
            await UpdateCanPublishStatus();; // אולי מצב הפרסום השתנה - צריך לבדוק
            CalcStats(); // חישוב מספר הפריטים לתצוגה של הלוח

        }
        else
        {
            contentMsg = "שגיאה בשמירה";
        }
    }
    
