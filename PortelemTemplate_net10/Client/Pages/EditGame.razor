    // ------- העלאת תמונה -------- //
    
    // פיצלנו לשתי פונקציות כי לקטגוריה ולפריט יש endpoints שונים בשרת לעדכון התמונה.
// בנוסף, כל אחת מעדכנת משתנה טעינה נפרד כדי שהספינר יופיע על הכרטיס הנכון.
    
    async Task UploadItemFile(InputFileChangeEventArgs e, ItemToSave item)
    {
        uploadingItem = item; // בכניסה לפונקציה התמונה בטעינה ושומרים את הפריט הספציפי
        var file = e.GetMultipleFiles().FirstOrDefault();
        if (file == null)
        {
            uploadingItem = null; // אין מה להראות טעינה
            return;
        }
        if (file.Size > maxFileSize) // במידה וגודל התמונה לא מתאים - ניתן חיווי למשתמש
        {
            contentMsg = "התמונה גדולה מדי - מקסימום 4MB";
            uploadingItem = null; //  עצירה במקרה של שגיאה
            return;
        }

        var buffer = new byte[file.Size];
        await file.OpenReadStream(maxFileSize).ReadAsync(buffer);
        var imageBase64 = Convert.ToBase64String(buffer);

        var saveRes = await Http.PostAsJsonAsync("api/Media/upload", imageBase64);
        if (saveRes.IsSuccessStatusCode)
        {
            string newFileName = await saveRes.Content.ReadAsStringAsync();
            item.Content = newFileName;
            item.IsImage = true;
            // שמירה מיידית של שם התמונה ב-DB
            if (item.ID > 0)
                await Http.PostAsJsonAsync($"api/EditGame/UpdateItemImage/{item.ID}", newFileName);
            MarkContentChanged(); // עדכון שהתוכן השתנה
        }

        uploadingItem = null; // בסיום הפונקציה התמונה עלתה ואפשר להפסיק אנימציה
    }

