    void CheckCanSave()
    {
        msg = "";
        // אם משהו השתנה באחד מהתכנים מהגרסה המקורית
        canSave = (gameToEdit.GameName != originalGame.GameName
                   || gameToEdit.RoundTime != originalGame.RoundTime
                   || gameToEdit.Instructions != originalGame.Instructions)
                  && !string.IsNullOrWhiteSpace(gameToEdit.GameName)
                  && !string.IsNullOrWhiteSpace(gameToEdit.Instructions);
    }

