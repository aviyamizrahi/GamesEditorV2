    async Task SaveGameSettings()
    // מטרת הפונקציה: בלחיצה על כפתור ״שמירה״ בהגדרות המשחק נשמור את הנתונים החדשים או המעודכנים של המשחק
    {
        gameToEdit.GameName = gameToEdit.GameName.Trim();
        gameToEdit.Instructions = gameToEdit.Instructions.Trim();
        // חקירה עצמית: הפונקציה Trim מוחקת רווחים מיותרים בהתחלה ובסוף לפני השליחה לשרת

        if (gameToEdit.ID == 0)
            // אם זה משחק חדש תקרא לפונקציה בשרת שיוצרת משחק חדש
        {
            var newGameRes = await Http.PostAsJsonAsync("api/Games/addGame", gameToEdit);
            if (newGameRes.IsSuccessStatusCode)
            {
                var newGame = await newGameRes.Content.ReadFromJsonAsync<GameToTableDTO>();
                gameToEdit.ID = newGame.ID; // נעדכן מזהה משחק
                displayName = gameToEdit.GameName; // נשים את שם המשחק בכותרת
                msg = "המשחק נוצר בהצלחה"; // נעדכן את המשתמש על יצירת משחק חדש בהצלחה
                canSave = false;
                originalGame = new GameToAddDTO // שמירת גרסה לתוך המשתנה
                {
                    GameName = gameToEdit.GameName,
                    RoundTime = gameToEdit.RoundTime,
                    Instructions = gameToEdit.Instructions
                };
                
               // כדי לטעון את העמוד מחדש עם הid החדש, נשתמש בNav שכבר הזרקנו לעמוד פה
               // בהתחלה הגדרנו forceLoad: false אבל אז נתקלנו בבעיה ויזואלית בתיבת הטקסט של הקטגוריה והפריטים והבנו שצריך לרענן את העמוד אחרי שמירה מוצלחת של משחק חדש - בשמירה של משחק קיים אין צורך לרענן 
                Nav.NavigateTo($"/EditGame/{gameToEdit.ID}", forceLoad: true);
                
            }
            else
            {
                msg = "משהו השתבש, המשחק לא נוצר";
            }
        }
        else
            // אם זה משחק קיים תעדכן את הפרטים בהתאם
        {
            var editRes = await Http.PostAsJsonAsync("api/EditGame/UpdateGame", gameToEdit);
            if (editRes.IsSuccessStatusCode)
            {
                displayName = gameToEdit.GameName; // עדכון הכותרת רק אחרי שמירה
                msg = "המשחק עודכן בהצלחה";
                canSave = false;
                originalGame = new GameToAddDTO
                {
                    GameName = gameToEdit.GameName,
                    RoundTime = gameToEdit.RoundTime,
                    Instructions = gameToEdit.Instructions
                };
            }
        }
    }

    void CancelChanges()
        // בלחיצה על ביטול שינויים נרצה להחזיר את הפרטים של המשחק האחרון שנשמר
    {
        gameToEdit = new GameToAddDTO
        {
            ID = gameToEdit.ID,
            GameName = originalGame.GameName,
            RoundTime = originalGame.RoundTime,
            Instructions = originalGame.Instructions
