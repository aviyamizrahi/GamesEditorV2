    }

    void DeleteCategoryImage(CategoryToSave cat) 
    // מטרת הפונקציה: לשמור את שמות התמונות שצריך למחוק בעת לחיצה על כפתור שמירת שינויים - כדי שהמקוריות לא יפגעו
    {
        if (string.IsNullOrWhiteSpace(cat.Content)) return;

        deletedImagePaths.Add(cat.Content); // שמירה למחיקה אחרי שמירה
        cat.Content = "";
        MarkContentChanged();
    }

}


