                            <circle cx="12" cy="12" r="12" fill="#8AC07F"/>
                            <path d="M10.6127 18C10.2507 18 9.98817 17.8546 9.7398 17.5494L6.26257 13.1302C6.07806 12.8976 6 12.6869 6 12.4615C6 11.9382 6.37611 11.5675 6.89415 11.5675C7.20639 11.5675 7.42637 11.6838 7.63217 11.96L10.5843 15.8122L16.3323 6.47244C16.5523 6.12356 16.7652 6 17.12 6C17.631 6 18 6.36342 18 6.87947C18 7.07571 17.9361 7.28649 17.7871 7.51908L11.4855 17.5276C11.2868 17.8401 10.9888 18 10.6127 18Z" fill="white"/>
