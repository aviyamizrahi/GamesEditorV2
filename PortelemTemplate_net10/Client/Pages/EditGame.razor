                        </svg>
                    }
                    מינימום 6 פריטים לקטגוריה
            </span>
            </div>
            <Tooltip Text="@(hasItemsInEmptyCategory ? "לא ניתן לשמור פריטים בתוך קטגוריה בלי תוכן" : "")" MaxWidth="150">
                <Button Variant="primary"
                        Text="שמירת שינויים"
                        Icon="@("<svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<g clip-path=\"url(#clip0_8_18374)\">\n<path d=\"M1.69048 0H14.358C14.4236 0.0373453 14.4555 0.0578376 14.5094 0.110929C14.7754 0.372725 15.0387 0.641718 15.3011 0.906926L16.78 2.39878L17.5426 3.16739C17.6777 3.30345 17.911 3.51103 18 3.66747V16.2927C17.9584 16.4104 17.9484 16.5457 17.908 16.67C17.7157 17.2625 17.2354 17.7393 16.639 17.9202C16.5641 17.9429 16.3783 17.9691 16.3189 18H1.69897C1.64297 17.9743 1.39598 17.93 1.30046 17.8968C0.782216 17.7166 0.317113 17.2799 0.125183 16.7616C0.100919 16.6968 0.0807063 16.6304 0.0646629 16.563C0.0501441 16.5006 0.0270241 16.3614 0 16.3099V1.68823C0.0236935 1.64331 0.0537291 1.48177 0.0694278 1.41917C0.0942811 1.32124 0.128097 1.22581 0.170448 1.13408C0.398485 0.646234 0.787467 0.284984 1.29617 0.104614C1.42369 0.0593972 1.57504 0.0452961 1.69048 0ZM3.51331 17.4646C3.5248 16.824 3.51606 16.1582 3.5161 15.5161L3.51617 11.913L3.51606 10.5097C3.51585 10.291 3.50314 9.88646 3.53633 9.69117C3.58046 9.4435 3.7029 9.21647 3.88564 9.04359C4.06035 8.87581 4.28333 8.767 4.52314 8.7326C4.66116 8.71351 4.8291 8.71771 4.97072 8.71777L5.54417 8.71821L7.50449 8.7185L11.3673 8.71852L12.6277 8.7182C12.8558 8.71806 13.0841 8.71756 13.3122 8.71905C13.6573 8.7213 13.9562 8.84602 14.195 9.10002C14.3481 9.26323 14.451 9.46723 14.491 9.68757C14.5223 9.86221 14.5129 10.1562 14.5129 10.3432L14.5126 11.3418V14.9722L14.5129 16.6165C14.5129 16.8718 14.5242 17.2158 14.5105 17.4622L15.4767 17.4644C16.0748 17.4647 16.5631 17.5262 17.0286 17.0612C17.3916 16.6986 17.4374 16.3462 17.438 15.8669L17.4377 8.02846L17.4379 5.32969C17.438 5.09001 17.4461 3.87439 17.4256 3.8533C16.7071 3.11592 15.2617 1.64313 14.582 0.971279C14.5678 0.957322 14.5532 0.943725 14.5383 0.930472C14.5469 1.18594 14.5402 1.47328 14.5401 1.73131L14.54 3.23781L14.5407 4.05143C14.5408 4.22975 14.5494 4.47508 14.5162 4.64396C14.4724 4.85964 14.3695 5.05