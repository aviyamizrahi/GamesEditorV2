 stroke-width=\"0.4\"/>\n<path d=\"M5.81588 15.1028C6.09447 15.088 6.51104 15.1009 6.80076 15.1009L8.74528 15.101L11.0165 15.1009C11.4147 15.1006 11.8122 15.099 12.2111 15.102C12.3546 15.0947 12.4881 15.1704 12.5113 15.3244C12.5389 15.5087 12.4233 15.637 12.2518 15.6688C11.9434 15.6855 11.5148 15.673 11.1988 15.673H9.19233L6.90171 15.6728L6.28553 15.6729C6.11874 15.674 5.81715 15.7035 5.66888 15.6229C5.53966 15.5526 5.50176 15.3358 5.59352 15.2207C5.66136 15.1355 5.71348 15.1192 5.81588 15.1028Z\" fill=\"#EBE3D8\" stroke=\"#EEE8DB\" stroke-width=\"0.2\"/>\n<path d=\"M5.79521 13.081C6.089 13.066 6.48386 13.0774 6.78435 13.0774L8.66567 13.0775L11.0278 13.0778C11.4182 13.0778 11.8087 13.0765 12.1991 13.0779C12.3544 13.0785 12.4714 13.1395 12.508 13.3011C12.5241 13.3732 12.51 13.4488 12.4688 13.5101C12.417 13.5881 12.3527 13.6205 12.2647 13.6392C11.9669 13.6554 11.5715 13.6443 11.2688 13.6443L9.43009 13.6443L7.02067 13.644C6.64482 13.6437 6.26899 13.6449 5.89318 13.6447C5.73538 13.6447 5.59057 13.5991 5.54838 13.4273C5.52966 13.3524 5.54275 13.273 5.58456 13.2081C5.64024 13.1226 5.70275 13.0982 5.79521 13.081Z\" fill=\"#EBE3D8\" stroke=\"#EEE8DB\" stroke-width=\"0.2\"/>\n<path d=\"M5.77273 11.0869C5.93526 11.0696 6.34544 11.0806 6.52225 11.0807L7.96063 11.0809L10.7141 11.0808C11.1951 11.0805 11.6765 11.0799 12.1575 11.0808C12.2105 11.0809 12.313 11.0822 12.3602 11.1039C12.4249 11.1336 12.4727 11.1855 12.4973 11.2528C12.5252 11.3307 12.5198 11.4167 12.4826 11.4904C12.4405 11.5721 12.3782 11.6101 12.2942 11.6374C12.1379 11.6568 11.6917 11.6462 11.5165 11.6461L9.97636 11.646H7.25278C6.79578 11.6461 6.33671 11.6479 5.87968 11.6454C5.81899 11.645 5.72563 11.6346 5.67428 11.6031C5.60939 11.5634 5.56364 11.4988 5.5478 11.4245C5.51322 11.2629 5.61429 11.1229 5.77273 11.0869Z\" fill=\"#EBE3D8\" stroke=\"#EEE8DB\" stroke-width=\"0.2\"/>\n<path d=\"M12.0599 1.63552C12.0988 1.63239 12.1383 1.63037 12.1767 1.63883C12.259 1.65696 12.33 1.70584 12.3711 1.78025C12.3956 1.82463 12.3988 1.89915 12.4017 1.94987C12.4128 2.14127 12.4157 3.69572 12.3831 3.78401C12.3486 3.87736 12.2721 3.92414 12.1857 3.96141C11.9361 3.99977 11.8411 3.83537 11.8423 3.61574C11.8452 3.0523 11.8364 2.48801 11.844 1.92463C11.8463 1.76292 11.9004 1.67865 12.0599 1.63552Z\" fill=\"#EBE3D8\"/>\n</g>\n<defs>\n<clipPath id=\"clip0_8_18374\">\n<rect width=\"18\" height=\"18\" fill=\"white\"/>\n</clipPath>\n</defs>\n</svg>\n")"
                        Disabled="@(!contentChanged || hasItemsInEmptyCategory)"
                        OnClick="SaveContent"/>
            </Tooltip>

        </div>
    </HeaderButtons>
    <ChildContent>
        @* ── פריטים ── *@
        <div class="items-section">
            <div class="content-header-col"> @* כותרת + כפתור הוספת פריט *@
                @if (selectedCategory != null)
                {
                    // כפתור הוספת פריט - קיים רק במידה ויש קטגוריה בחורה
                    <Button Variant="primary"
                            AdditionalClass="btn-large"
                            Icon="@("<svg width=\"23\" height=\"23\" viewBox=\"0 0 23 23\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<path d=\"M0 11.5C0 11.0479 0.163633 10.6583 0.490898 10.3312C0.818163 10.0042 1.20799 9.84065 1.66039 9.84065H9.84683V1.67378C9.84683 1.22166 10.0056 0.832079 10.3233 0.505019C10.6506 0.16834 11.0452 0 11.5072 0C11.9692 0 12.3591 0.16834 12.6767 0.505019C13.004 0.832079 13.1676 1.22166 13.1676 1.67378V9.84065H21.354C21.8064 9.84065 22.1915 10.0042 22.5091 10.3312C22.8364 10.6583 23 11.0479 23 11.5C23 11.9617 22.8364 12.3561 22.5091 12.6832C22.1915 13.0102 21.8064 13.1738 21.354 13.1738H13.1676V21.3407C13.1676 21.7928 13.004 22.1824 12.6767 22.5094C12.3591 22.8365 11.9692 23 11.5072 23C11.0452 23 10.6506 22.8365 10.3233 22.5094C10.0056 22.1824 9.84683 21.7928 9.84683 21.3407V13.1738H1.66039C1.20799 13.1738 0.818163 13.0102 0.490898 12.6832C0.163633 12.3561 0 11.9617 0 11.5Z\" fill=\"#EBE3D8\"/>\n</svg>\n")"
                            Text=""
                            OnClick="AddItem"/>
                }
                <h3>פריטים</h3>
            </div>
            
            <div class="items-grid-col">
                @if (selectedCategory == null) // אם אין קטגוריה בחורה אז נגיד למשתמש שהוא צריך לבחור אחת
                {
                    <p>להוספת פריטים יש לבחור קטגוריה</p>
                }

                else
                {
                    <div class="items-grid-wrapper"></div>
                    <div class="items-grid">
                        @for (int i = 0; i < selectedCategory.Items.Count; i++)
                        {
                            ItemToSave item = selectedCategory.Items[i];
                            string itemInputId = "item_" + i.ToString();

                            <ItemCard @key="item"
                                      Item="item"
                                      Index="i"
                                      CanDelete="@(!(string.IsNullOrWhiteSpace(item.Content) && selectedCategory.Items.Count <= minItems) || item.ID > 0)"
                                      ItemInputId="@itemInputId"
                                      OnDelete="() => RemoveItem(item)"
                                      OnImageDelete="() => DeleteItemImage(item)"
                                      OnImageUpload="(e) => UploadItemFile(e, item)"
                                      OnContentChanged="MarkContentChanged"
                                      OnTextClear="() => { item.Content = string.Empty; MarkContentChanged(); }"
                                      IsUploading="@(uploadingItem == item)"/>
                        }
                    </div>
                }
            </div>
           

            @* ── לוח סבבים ── *@
            @if (showBoard)
            {
                <div class="board-wrapper">
                    <div class="board-img-wrapper">
                        <img src="Images/RoundsBoard.png" width="170" height="221" alt="לוח להצגת סטטוס הסבבים במשחק"/>
                    </div>
                    <div class="board-text-wrapper">
                        <span>סה״כ פריטים במשחק: </span> <b>@totalItems</b> <br/>
                        @if (gameStatus.CanPublish) // רק אם בכלל המשתמש עומד בתנאים לצירת משחק המידע יסופק לו
                        {
                        <span>כמות סבבים נוכחית: </span> <b>@rounds</b> <br/> <br/>
                        @if (missingItems > 0 && totalItems >= 18)
                        {
                        <span>שימו לב ! כדי להשלים סבב נוסף יש להוסיף עוד </span>
                        <b>@missingItems</b>
                        <span>פריטים</span>
                        }
                        }
                        
                    </div>
                </div>

            }

        </div>
        <hr class="between-itms-to-cats"/>

        @* ── קטגוריות ── *@
        <div class="cats-section">
            <div class="content-header-col">
                @* כפתור + קטגוריה — מוצג רק אם יש פחות מ-5 *@
                @if (categories.Count < 5)
                {
                    <Button Variant="primary"
                            AdditionalClass="btn-large"
                            Icon="@("<svg width=\"23\" height=\"23\" viewBox=\"0 0 23 23\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<path d=\"M0 11.5C0 11.0479 0.163633 10.6583 0.490898 10.3312C0.818163 10.0042 1.20799 9.84065 1.66039 9.84065H9.84683V1.67378C9.84683 1.22166 10.0056 0.832079 10.3233 0.505019C10.6506 0.16834 11.0452 0 11.5072 0C11.9692 0 12.3591 0.16834 12.6767 0.505019C13.004 0.832079 13.1676 1.22166 13.1676 1.67378V9.84065H21.354C21.8064 9.84065 22.1915 10.0042 22.5091 10.3312C22.8364 10.6583 23 11.0479 23 11.5C23 11.9617 22.8364 12.3561 22.5091 12.6832C22.1915 13.0102 21.8064 13.1738 21.354 13.1738H13.1676V21.3407C13.1676 21.7928 13.004 22.1824 12.6767 22.5094C12.3591 22.8365 11.9692 23 11.5072 23C11.0452 23 10.6506 22.8365 10.3233 22.5094C10.0056 22.1824 9.84683 21.7928 9.84683 21.3407V13.1738H1.66039C1.20799 13.1738 0.818163 13.0102 0.490898 12.6832C0.163633 12.3561 0 11.9617 0 11.5Z\" fill=\"#EBE3D8\"/>\n</svg>\n")"
                            Text=""
                            OnClick="AddCategory"/>
                }
                <h3>קטגוריות</h3>
            </div>
            <div class="cats-grid">
                @for (int i = 0; i < categories.Count; i++)
                    // שימוש בלולאת for כדי להבדיל את כפתורי הרדיו של כל אחת מהקטגוריות הריקות שאין להן עדיין id
                {
                    CategoryToSave cat = categories[i]; // שימוש יותר נוח בקטגוריה הנוכחית בלולאה
                    string catInputId = "cat_" + i.ToString(); // שימוש באינדקס במקום ID כדי למנוע התנגשות בין קטגוריות ריקות
                    <div></div>
                    <CategoryBox @key="cat"
                                 Cat="cat"
                                 IsSelected="@(selectedCategory == cat)"
                                 Index="i"
                                 CanDelete="@(!(string.IsNullOrWhiteSpace(cat.Content) && categories.Count <= minCategories) || cat.ID > 0)"
                                 OnSelect='() => SelectCategory(cat)'
                                 OnDelete='() => RemoveCategory(cat)'
                                 OnImageDelete="() => DeleteCategoryImage(cat)"
                                 OnImageUpload="(e) => UploadCategoryFile(e, cat)"
                                 OnContentChanged="MarkContentChanged"
                                 CatInputId="@catInputId"
                                 OnTextClear="() => { cat.Content = string.Empty; MarkContentChanged(); }"
                                 IsUploading="@(uploadingCategory == cat)"/>
                    @* אם הקטגוריה הנוכחית היא זו שנבחרה — מוסיפים מחלקת עיצוב מודגשת, אחרת ללא מחלקה *@
                    @* שולחת את הערך החדש לקומפוננטת אב כדי לעדכן את הטקסט החדש *@
                    @* בלחיצה על תיבת הטקסט הקטגוריה תיבחר *@
                    @* מחיקת קטגוריה — stopPropagation מונע בחירת הקטגוריה בעת לחיצה על מחק *@
                    @* IsUploading מעביר true רק לקטגוריה שמתבצעת בה כרגע העלאת תמונה — כך הספינר יופיע רק עליה ולא על כולן *@
                }
            </div>
        </div>

        <p class="msg">@contentMsg</p>
    </ChildContent>
</AccordionSection>

@* ── פופאפים ── *@

<PopUp IsVisible="@showPublishPopup"
       Title="פרסום משחק"
       ConfirmText="פרסום משחק"
       CancelText="ביטול"
       OnConfirm="ConfirmPublish"
       OnCancel="() => showPublishPopup = false"
       OnClose="() => showPublishPopup = false">
    <p>האם ברצונך לפרסם את המשחק "@displayName" לפי עונות השנה?</p>
    <p>קוד משחק: @gameStatus.GameCode</p>
</PopUp>

<PopUp IsVisible="@showDeleteCategoryPopup"
       Title="מחיקת קטגוריה"
       ConfirmText="מחיקה"
       CancelText="ביטול"
       OnConfirm="() => DeleteCategory(categoryToDelete)"
       OnCancel="() => showDeleteCategoryPopup = false"
       OnClose="() => showDeleteCategoryPopup = false"
       ShowWarningIcon="@(deleteBreaksPublish)">
    @if (deleteBreaksPublish)
    {
        <span>לקטגוריה זו קיימים
            @categoryToDeleteItemsCount
            פריטים,</span>
        <span>המחיקה תגרום לאי עמידה בתנאי הפרסום, האם למחוק בכל זאת?</span>
        <CategoryPreview Cat="categoryToDelete"></CategoryPreview>
    }
    else
    {
        <span>לקטגוריה זו קיימים @categoryToDeleteItemsCount פריטים,</span>
        <span>האם למחוק בכל זאת?</span>
        <CategoryPreview Cat="categoryToDelete"></CategoryPreview>
    }
</PopUp>

<PopUp IsVisible="@showUnsavedChangesPopup"
       Title="שמירת שינויים"
       ConfirmText="שמור שינויים"
       CancelText="לא לשמור"
       OnConfirm="SaveAndNavigate"
       OnCancel="NavigateWithoutSaving"
       OnClose="() => showUnsavedChangesPopup = false">
    <span>לפני חזרה לעמוד המשחקים שלי,</span><br/>
    <span>האם לשמור את השינויים שבוצעו?</span>
</PopUp>

@code {

    // ── פרמטר ── //
    [Parameter] public int gameIdToEdit { get; set; }

    // ── פרסום המשחק ── //
    GameToTableDTO gameStatus = new GameToTableDTO();
    bool wasEverPublished = false; // כדי להראות אנימציה - האם המשחק כבר פורסם
    
    // ── הגדרות משחק ── //
    GameToAddDTO gameToEdit = new GameToAddDTO();
    GameToAddDTO originalGame = new GameToAddDTO();
    string displayName = ""; // שם המשחק בכותרת — מתעדכן רק אחרי שמירה
    bool noLimit = false;
    bool canSave = false;
    string msg = "";
    bool isSettingsOpen; // במידה וזה משחק חדש האקורדיון של ההגדרות יהיה כבר פתוח
    bool showPublishPopup = false; // האם להראות פופ אפ פרסום
    bool showUnsavedChangesPopup = false; // פופ-אפ שמירת שינויים (בלחיצה על ״בחזרה למשחקים שלי״)

    
    // ── עריכת תוכן ── //
    List<CategoryToSave> categories = new List<CategoryToSave>();
    CategoryToSave selectedCategory = null;
    bool contentChanged = false;
    string contentMsg = "";
    // רשימות של IDs שנמחקו — ישלחו לשרת בעת שמירה
    List<int> deletedCategoryIds = new List<int>();
    List<int> deletedItemIds = new List<int>();
    bool hasItemsInEmptyCategory = false; // אם יש פריטים בקטגוריה ללא תוכן לא נאפשר למשתמש לשמור ונציג טולטיפ הסבר
    List<int> catsIdsWithItemsEmptyContent = new List<int>(); // רשימה של מספרי id של קטגוריות שהן ריקות מתוכן אבל יש בהן פריטים

    
    // ── ספירת סבבים ── //
    int totalItems = 0; // ספירת פריטים
    int rounds = 0; // ספירת סבבים
    int missingItems = 0; // כמה פריטים צריך להוסיף עד להשלמת סבב נוסף במשחק
    bool showBoard = false; // נרצה שיראו את הלוח רק במידה ויש לפחות קטגוריה אחת עם תוכן
    
    // ── מחיקת קטגוריה ── //
    bool showDeleteCategoryPopup = false;
    CategoryToSave categoryToDelete = null;
    string categoryToDeleteItemsCount = ""; // בשביל הפופ-אפ
    bool deleteBreaksPublish = false;
    
    // ── העלאת תמונה ── //
    long maxFileSize = 4194304;
    List<string> deletedImagePaths = new List<string>(); // רשימה שתשמור את שמות התמונות שצריך למחוק - במקום למחוק אותן מיד מהשרת
    ItemToSave uploadingItem = null; // לצורך הצגת אנימציית טעינת תמונה על פריט
    CategoryToSave uploadingCategory = null; // לצורך הצגת אנימציית טעינת תמונה על קטגוריה

    
    // ── תנאים למינימום פיריטים וקטגוריות ── //
    int minCategories = 3; // מינימום קטגוריות
    int minItems = 6; // מינימום פריטים לקטגוריה
    bool hasMinCategories = false; // האם עומד בתנאי
    bool hasMinItemsPerCategory = false; // האם עומד בתנאי
    

    // ── טעינה ראשונית ── //
    protected override async Task OnParametersSetAsync()
        // כאשר הוגדר פרמטר וקיבלנו מספר דרך הנתיב
    {
       
        if (gameIdToEdit == 0) // אם זה משחק חדש
        {
            gameToEdit = new GameToAddDTO(); // איפוס משתנה
            originalGame = new GameToAddDTO(); // איפוס המשתנה
            isSettingsOpen = true; // אם זה משחק חדש האקורדיון צריך להיות פתוח בהגדרות המשחק
        }
        else if (gameIdToEdit > 0) // אם זה משחק קיים
        {
            isSettingsOpen = false; // סגור במידה וזה משחק קיים - המשתמש יבחר מה לפתוח קודם
            await LoadGameSettings(); // טעינת הגדרות
            await LoadPublishStatus(); // טעינת סטטוס פרסום
            await LoadGameContent(); // טעינת תוכן (קטגוריות ופריטים)
        }
    }

    async Task LoadGameSettings()
// טעינת הגדרות המשחק מהשרת
    {
        var gameRes = await Http.GetAsync($"api/EditGame/GetGame/{gameIdToEdit}");
        if (gameRes.IsSuccessStatusCode)
        {
            gameToEdit = await gameRes.Content.ReadFromJsonAsync<GameToAddDTO>();

            if (gameToEdit.RoundTime == 0)
                noLimit = true;
            // אם הנתון של ללא הגבלה מסומן אז גם הצ׳ק בוקס צריך להופיע מסומן

            originalGame = new GameToAddDTO
            {
                GameName = gameToEdit.GameName,
                RoundTime = gameToEdit.RoundTime,
                Instructions = gameToEdit.Instructions
            };
            displayName = gameToEdit.GameName;
        }
    }


    async Task LoadPublishStatus()
    {
        var publishRes = await Http.GetAsync($"api/EditGame/GetPublishStatus/{gameIdToEdit}");
        if (publishRes.IsSuccessStatusCode)
        {
            gameStatus = await publishRes.Content.ReadFromJsonAsync<GameToTableDTO>(); // שמירת מצב הפרסום הנוכחי אחרי לחיצה על כפתור ״שמירת שינויים״
            if (gameStatus.IsPublish)
                wasEverPublished = true; // בשביל האנימציה 
        }
    }

    async Task UpdateCanPublishStatus()
    {
        await Http.PostAsync($"api/Games/CheckCanPublish/{gameToEdit.ID}", null);
        await LoadPublishStatus();
    }

    async Task LoadGameContent()
        // מטרת הפונקציה: טעינת תוכן המשחק מהשרת — קטגוריות ופריטים
// בנוסף: השלמת פלייסהולדרים למינימום, וחישוב עמידה בתנאי פרסום        
    {
        gameIdToEdit = gameToEdit.ID;
        categories = new List<CategoryToSave>();
        selectedCategory = null;
        if (gameToEdit.ID > 0)
        {
        // מאפס את הרשימה ואת הקטגוריה הבחורה כל טעינה מחדש ומונע כפילויות
        var res = await Http.GetAsync($"api/EditGame/GetGameContent/{gameToEdit.ID}");
        if (res.IsSuccessStatusCode)
        {
        var fullGame = await res.Content.ReadFromJsonAsync<FullGameToSave>();
        if (fullGame != null)
        categories = fullGame.Categories; // כל המידע נמצא פה ברשימת הקטגוריות - כל קטגוריה מכילה רשימת פריטים
        else
        categories = new List<CategoryToSave>(); // אם אין תוכן כלל אז תיצור רשימה ריקה - ישמש לבדיקה לפלייסהולדרים
        }

        // השלמה למינימום 3 קטגוריות עם פלייסהולדרים ריקים
        while (categories.Count < minCategories)
        {
        categories.Add(new CategoryToSave { Items = new List<ItemToSave>() });
        // כל עוד יש לנו פחות מ3 קטגוריות תשלים מידע ריק כדי להראות פלייסהולדרים
        }


        int validCategoriesCount = 0; // לצורך הצגת עמידות בתנאי פרסום
        int categoriesWithContent = 0; // לצורך הצגת עמידות בתנאי פרסום

        foreach (var cat in categories)
        {
        EnsureMinItems(cat); // השלמת פריטים למינימום 6 לכל קטגוריה 

        if (!string.IsNullOrWhiteSpace(cat.Content)) // אם יש תוכן בקטגוריה
        {
        categoriesWithContent++; // לסכום את הקטגוריות שיש בהן תוכן

        int itemsWithContent = 0; // פריטים שיש בהם תוכן
        foreach (var item in cat.Items) // מעבר על כל הפריטים בקטגוריה
        {
        if (!string.IsNullOrWhiteSpace(item.Content)) // אם יש תוכן 
        itemsWithContent++; // לסכום 
        }
        if (itemsWithContent >= minItems) // אם יש לפחות 6 פריטים בקטגוריה בעלי תוכן
        validCategoriesCount++; // הקטגוריה נספרת כאחת שעומדת בתנאים
        }
        }

        hasMinCategories = categoriesWithContent >= minCategories; // תנאי: אם מספר הקטגוריות שעומדות בתנאים יותר גדול או שווה למינימום אז המשתנה חיובי 
        hasMinItemsPerCategory = categoriesWithContent > 0 && validCategoriesCount == categoriesWithContent;
        // אם יש 3 קטגוריות עם תוכן מינימום ושלותשתן עומדות בתנאים של מינימום פריטים לקטגוריה
        CalcStats();
        }
         
    }

    async Task ConfirmPublish()
// אישור פרסום המשחק לאחר לחיצה על כפתור האישור בפופ אפ     
    {
       
        PublishGame publishData = new PublishGame { ID = gameToEdit.ID, IsPublish = true };
        // יוצרים משתנה חדש עם מזהה המשחק ו-IsPublish=true כדי לפרסם

        var res = await Http.PostAsJsonAsync("api/Games/publishGame", publishData);
        if (res.IsSuccessStatusCode)
        {
            showPublishPopup = false;
            // סגירת הפופ אפ
            gameStatus.IsPublish = true;
            // עדכון המשתנה בעמוד כדי שהכפתור יתחלף ויזואלית

            if (!wasEverPublished)
            {
                wasEverPublished = true;
                // סימון שהמשחק פורסם לראשונה — כדי שהאנימציה תופיע רק הפעם
                await StartConfetti(); // קונפטיייי (: 

            }
        }
    }

    async Task UnpublishGame()
// ביטול פרסום המשחק    
    {
        PublishGame publishData = new PublishGame { ID = gameToEdit.ID, IsPublish = false };
        //  משתנה מסוג PublishGame עם מזהה המשחק ו-IsPublish=false כדי לבטל פרסום

        var res = await Http.PostAsJsonAsync("api/Games/publishGame", publishData);
        // שולחים את המשתנה החדש לשרת כדי לבטל פרסום

        if (res.IsSuccessStatusCode)
        {
            gameStatus.IsPublish = false;
            // אם השרת אישר — מעדכנים את המשתנה בעמוד כדי שנראה גם ויזואלית את השינוי
        }
    }

    void EnsureMinItems(CategoryToSave cat)
        // השלמת רשימת הפריטים של קטגוריה למינימום 6 — רק אם יש לה תוכן
    {
        if (cat.Items == null)
            cat.Items = new List<ItemToSave>();

        if (selectedCategory != null) // אם יש קטגוריה שנבחרה
        {
            while (cat.Items.Count < minItems) // כל עוד רשימת הפריטים מונה פחות מכמות הפריטים המינימלית (6 פריטים)
            {
                cat.Items.Add(new ItemToSave { CategoryID = cat.ID }); // תשלים מידע ריק בשביל הפלייסהולדרים
            }
        }
    }

    void SelectCategory(CategoryToSave cat)
        // בחירת קטגוריה — גם משלימה את הפריטים שלה למינימום
    {
        selectedCategory = cat;
        EnsureMinItems(cat);
    }

    // ── הוספת קטגוריה / פריט ── //

    void AddCategory()
        // הוספת קטגוריה ריקה חדשה (עד מקסימום 5) בלחיצה על כפתור +
    {
        if (categories.Count < 5)
        {
            categories.Add(new CategoryToSave { Items = new List<ItemToSave>() });
        }
    }

    void AddItem()
        // הוספת פריט ריק לקטגוריה הנבחרת
    {
        if (selectedCategory != null)
        {
            selectedCategory.Items.Add(new ItemToSave { CategoryID = selectedCategory.ID });
        }
    }

    // ── מחיקת קטגוריה / פריט ── //

    void RemoveCategory(CategoryToSave cat)
    {
        bool hasItems = false; // כדי לבדוק אם יש בקטגוריה פריטים או לא (משפיע על התצוגה בפופ אפ ועל התנהגות המחיקה)
        bool catIsValid = false;
        int itemsCount = 0; // בשביל התצוגה בפופ אפ 
        int validCategoriesCount = 0; // יכיל את כל הקטגוריות בעלות מינימום פריטים (חוץ מזו שנרצה למחוק)

        if (cat.Items != null) // לסכום את מספר הפריטים של הקטגוריה הנוכחית שנרצה למחוק
        {
            foreach (ItemToSave item in cat.Items)
            {
                if (!string.IsNullOrWhiteSpace(item.Content))
                {
                    hasItems = true; // משתנה חיובי - יש פריטים לקטגוריה
                    itemsCount++; // מציג כמה פריטים יש לה
                }
            }
        }

        if (itemsCount >= minItems)
        {
            catIsValid = true; // רק במידה ויש לקטגוריה מספיק פריטים אז היא עומדת בתנאים
        }
        
        foreach (CategoryToSave c in categories)
        {
            if (c == cat) 
            {
                continue; // נרצה לבדוק את כל הקטגוריות האחרות ולא את זאת שמוחקים
            }

            if (!string.IsNullOrWhiteSpace(c.Content)) // אם יש תוכן לקטגוריה
            {
                int itemsWithContent = 0; // יסכום את הקטגוריות
                foreach (ItemToSave item in c.Items) // מעבר על הפריטים של אותה קטגוריה
                {
                    if (!string.IsNullOrWhiteSpace(item.Content)) // אם לפריט הזה יש תוכן
                        itemsWithContent++; // תסכום גם אותו
                }

                if (itemsWithContent >= minItems) // אם הקטגוריה עומדת בתנאי הפרסום - מינימום פריטים לכל קטגוריה
                    validCategoriesCount++; // תסכום לקטגוריות שעומדות בתנאי פרסום
            }
        }

        if (gameStatus.CanPublish && catIsValid && validCategoriesCount < minCategories)
            // בדיקה של 3 תנאים
            // 1. אם המשחק ניתן לפרסום
            // 2. אם הקטגוריה שאנחנו רוצים למחוק היא עומדת בתנאים
            // 3. אם הקטגוריות התקינות האחרות יותר קטנות מהמינימום הנדרש
        {
            deleteBreaksPublish = true; // אז תנאי הפרסום נשברים
        }
        else 
            // אם לא אז או שלא עמדנו בתנאי פרסום או שיש יותר קטגוריות תקינות מהמינימום
        { 
            deleteBreaksPublish = false;
        }
        
        if (hasItems || deleteBreaksPublish)
            // פתיחת פופ אפ אם יש פריטים או שהמחיקה תשבור תנאי פרסום
        {
            categoryToDelete = cat;
            categoryToDeleteItemsCount = itemsCount.ToString();
            showDeleteCategoryPopup = true;
        }
        else // אם אין לקטגוריה תוכן של טקסט / תמונה אפשר למחוק אותה פשוט בלי הגנה
        {
            DeleteCategory(cat);
            // מחיקה ישירה ללא וידוא
        }
    }



    void DeleteCategory(CategoryToSave cat)
// מחיקת הקטגוריה בפועל    
    {
        if (cat.ID > 0)
            deletedCategoryIds.Add(cat.ID); // כדי לעדכן בכפתור שמירה

        categories.Remove(cat); // עדכון ויזואלי

        if (selectedCategory == cat)
            selectedCategory = null; // איפוס הקטגוריה שנבחרה

        while (categories.Count < minCategories) // אם מספר הקטגוריות עכשיו קטן מהמינימום צריך להוסיף פלייסהולדר
        {
            categories.Add(new CategoryToSave { Items = new List<ItemToSave>() });
        }

        MarkContentChanged(); // יש שינוי בעריכת התוכן
        showDeleteCategoryPopup = false; // סגירת הפופ-אפ
        categoryToDelete = null; // איפוס קטגוריה למחיקה
    }

    void RemoveItem(ItemToSave item)
        // מחיקת פריט — אם היה שמור בבסיס הנתונים נוסיף ל-DeletedItemIds
    {
        if (item.ID > 0)
            deletedItemIds.Add(item.ID);

        selectedCategory.Items.Remove(item);

        // שמירה על מינימום 6 פריטים ויזואלית אם לקטגוריה יש תוכן
        EnsureMinItems(selectedCategory);

        MarkContentChanged();
    }

    // ── ניקוי של הפריטים והקטגוריות הריקות לפני השמירה לשרת!! ── //

    async Task CleanContentBeforeSave()
// מטרת הפונקציה: ניקוי פריטים וקטגוריות ריקות לפני שמירה — מחיקה מהשרת אם יש id     
    // מטרת הפונקציה גם לנקות רווחים מיותרים לפריטים וקטגוריות שיש להם תוכן טקסטואלי
    {
        foreach (var cat in categories) // מעבר על כל הקטגוריות
        {
            int itemsWithContent = 0; // נספור פריטים שיש להם תוכן כדי להשתמש בתנאי של הקטגוריות
            foreach (var item in cat.Items) // מעבר על כל הפריטים
            {
                if (string.IsNullOrWhiteSpace(item.Content)) // אם אין תוכן כלשהו
                {
                    if (item.ID > 0) // ויש id - זאת אומרת שהפריט היה שמור במערכת 
                        deletedItemIds.Add(item.ID); // נוסיף את הפריט לרשימה שמוחקת את הפריטים
                }
                else
                {
                    itemsWithContent++; // סופרים פריטים עם תוכן
                    if (!item.IsImage) // אם זה טקסט ולא תמונה - תנקה רווחים מיותרים לפני שליחה לשרת
                    {
                        item.Content = item.Content.Trim();
                    }
                }
            }

            // קטגוריה בלי תוכן (תמונה או טקסט) וגם ללא פריטים עם תוכן וגם שהייתה כבר שמורה במערכת — צריך למחוק אותה
            if (string.IsNullOrWhiteSpace(cat.Content) && itemsWithContent == 0 && cat.ID > 0 )
            {
                    deletedCategoryIds.Add(cat.ID);
            }
            else
            {
                if (!string.IsNullOrWhiteSpace(cat.Content) && !cat.IsImage) // קטגוריות שכן יש בהם תוכן נרצה פשוט לנקות רווחים מיותרים
                {
                    cat.Content = cat.Content.Trim();
                }
            }
        }
    }
    
    

