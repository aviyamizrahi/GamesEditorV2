@using AuthTemplate.Shared.EditGameContentDTOs

@* קומפוננטת של פריט *@

<style>
    .item-card-wrapper {
        position: relative;
        margin: 10px 32px;
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        width: 134px;
        box-sizing: border-box;
    }

    .item-box {
        position: relative;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
    }

    /* כפתור הפח */
    .delete-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: none;
        background: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #000000;
        padding: 0;
        opacity: 0;  /* ברירת מחדל: הפח שקוף ולא ניתן ללחוץ עליו */
        pointer-events: none;
        transition: opacity 0.15s ease-in-out, background-color 0.15s ease-in-out;
    }

    .item-card-wrapper .tooltip-wrapper.item-delete-btn {
        position: absolute;
        top: 40%;
        right: 134px;
        transform: translateY(-50%);
        z-index: 30;
    }

    .item-card-wrapper .tooltip-wrapper .tooltip-box.item-delete-btn {
        margin-top: 14px;
    }
    /*איך הפח נראה במידה וניתן למחוק את הפריט*/
    .item-card-wrapper:hover .delete-btn:not(:disabled) {
        opacity: 1;
        pointer-events: auto;
    }
    .item-card-wrapper:focus  .delete-btn:not(:disabled) {
        opacity: 1;
        pointer-events: auto;
        border: 2px solid blue;
    }
    /* איך הפח נראה במידה ולא ניתן למחוק את הפריט*/
    .item-card-wrapper:hover .delete-btn:disabled {
        opacity: 0.3 !important;
        pointer-events: none !important;
    }

    /* כיסוי אדום - מוצג בעת הובר על הפח */
    .red-overlay {
        position: absolute;
        top: 0;
        left: 0;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.15s ease-in-out;
        z-index: 10;
    }

    .item-card-wrapper:has(.delete-btn:hover:not(:disabled)) .red-overlay {
        opacity: 1;
    }

    /* תוכן הפריט */
    .item-content {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        width: 90%;
        height: 85%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 5;
    }

    .item-image {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        cursor: pointer;
    }
    
    /* איקס למחיקת תוכן של פריט */
    .remove-content-btn-item {
        position: absolute;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.08s ease-in-out;
        top: -1px;
        right: -1px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        z-index: 10;
        background: none;
        border: none;
        outline: none;
    }
    .item-card-wrapper:hover .remove-content-btn-item,
    .item-card-wrapper:focus-within .remove-content-btn-item { 
        opacity: 1;
        pointer-events: auto;
    }
    
    /* חיווי ויזואלי לטעינת תמונה */
    .upload-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        background: none;
        border: none;
        cursor: pointer;
        width: 100%;
        height: 100%;
    }
    .upload-btn:focus {
        border: 2px solid blue;
    }

    .upload-btn span {
        font-size: 10px;
        text-align: center;
        color: black;
    }

    /* כפתורי רדיו לטקסט או תמונה */
    .item-type-radios {
        display: flex;
        gap: 12px;
        direction: ltr;
        margin-top: 8px;
        height: 20px;
        z-index: 20;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.15s ease-in-out;
    }

    .item-card-wrapper:hover .item-type-radios {
        opacity: 1;
        pointer-events: auto;
    }

    .radio-label {
        display: flex;
        align-items: center;
        gap: 4px;
        cursor: pointer;
    }

    .radio-label input[type="radio"] {
        appearance: none;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 0.1px solid black;
        background-color: #D9D9D9;
        box-shadow: inset 0 0.2px 0.2px rgba(0, 0, 0, 0.25);
        position: relative;
        cursor: pointer;
        transition: all 0.15s ease-in-out;
    }

    .radio-label input[type="radio"]:checked::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: #555;
    }

    .radio-label:has(input:disabled) {
        opacity: 0.3;
        cursor: not-allowed;
    }
    
    .item-box.invalid { 
        outline: 2.5px solid #FF8080;
    }

    .upload-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 20;
    }

    .spinner {
        width: 30px;
        height: 30px;
        border: 3px solid #eee;
        border-top: 3px solid #911627;
        border-radius: 50%;
        animation: spin 0.2s linear infinite;
    }

    
</style>


