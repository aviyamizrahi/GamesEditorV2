                <input type="radio"
                       name="item-type-@Index"
                       checked="@Item.IsImage"
                       disabled="@(!string.IsNullOrWhiteSpace(Item.Content) && !Item.IsImage)"
                       @onchange="() => { Item.IsImage = true; OnContentChanged.InvokeAsync(); }"/>
            </label>
        }
    </div>

</div>

@* פופאפ הגדלת תמונה *@
@if (showImagePopup)
{
    <PopUp IsVisible="@showImagePopup"
           Title="הגדלת תמונה"
           ShowButtons="false"
           OnClose="() => showImagePopup = false">
        <img src="uploadedFiles/@Item.Content" alt="פריט" style="max-width: 100%; max-height: 400px; object-fit: contain;"/>
    </PopUp>
}

@code {
    [Parameter] public ItemToSave Item { get; set; } // מופע של פריט - מכיל את כל התוכן
    [Parameter] public int Index { get; set; } // מספר הפריט בלולאה בשביל הlabel
    [Parameter] public bool CanDelete { get; set; } // האם ניתן למחוק את הפריט
    [Parameter] public string ItemInputId { get; set; } // מספר id כדי להבדיל בhtml את הפריט 
    [Parameter] public EventCallback OnDelete { get; set; } // במחיקת פריט
    [Parameter] public EventCallback OnImageDelete { get; set; } // במחיקת תמונה
    [Parameter] public EventCallback<InputFileChangeEventArgs> OnImageUpload { get; set; } // בהעלאת תמונה
    [Parameter] public EventCallback OnContentChanged { get; set; } // בשינוי של תוכן
    [Parameter] public EventCallback OnTextClear { get; set; } // מחיקת התוכן הטקסטואלי
    [Parameter] public bool IsUploading { get; set; } = false; // חיווי בזמן טעינה של תמונה
    
    bool showImagePopup = false;
    
}