@using AuthTemplate.Shared.EditGameContentDTOs

@* קומפוננטת קרטון קטגוריה *@

<style>
    .category-card-wrapper {
        position: relative;
        margin: 25px;
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        width: 156px; /* מותאם לרוחב המקסימלי של הקופסה הגדולה כדי שלא יקפוץ הצידה */
        height: 145px; /* נותן מספיק מקום קבוע לקופסה + לרדיו בטונס למטה */
        box-sizing: border-box;
    }

    .category-box {
        position: relative;
        cursor: pointer;
        height: 116px; /* גובה מקסימלי קבוע של הקופסה */
        display: flex;
        align-items: flex-end; /* מבטיח שהקופסאות יושבות על אותו קו תחתון */
        justify-content: center;
        width: 100%;
    }

    /* כפתור הפח — ממוקם בפינה הימנית העליונה של הקופסה */
    /* כפתור הפח — ממוקם מחוץ לקופסה בצד שמאל */
    .delete-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: none;
        background: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #000000;
        padding: 0;
        opacity: 0;  /* ברירת מחדל: הפח שקוף ולא ניתן ללחוץ עליו */
        pointer-events: none;
        transition: opacity 0.15s ease-in-out, background-color 0.15s ease-in-out;
    }

    .category-card-wrapper .tooltip-wrapper.cat-delete-btn {
        position: absolute;
        top: 50%;
        right: 150px;
        transform: translateY(-50%);
        z-index: 30;
    }

    .category-card-wrapper .tooltip-wrapper .tooltip-box.cat-delete-btn {
        margin-top: 14px; 
    }

    .category-card-wrapper:has(.selected) .tooltip-wrapper.cat-delete-btn {
        right: 163px; /* קצת יותר שמאל כשהקרטון גדול */
    }

    /* אם ניתן ללחוץ על הפח אז מציג צבע מלא*/
    .category-card-wrapper:hover .delete-btn:not(:disabled) {
        opacity: 1;
        pointer-events: auto;
    }

    /* hoverאם לא ניתן ללחוץ על הפח אז מציג את הפח בשקיפות */
    .category-card-wrapper:hover .delete-btn:disabled {
        opacity: 0.3 !important;
        pointer-events: none !important;
        cursor: not-allowed;
    }
    
    

    /* התוכן (טקסט/תמונה) ממוקם מעל ה-SVG */
    .box-content {
        position: absolute;
        bottom: 8px; /* מעוגן יחסית לתחתית הקופסה כדי שלא יקפוץ בין מצבים */
        left: 50%;
        transform: translateX(-50%);
        width: 70%;
        height: 65px;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 5;
        padding: 6px;
        box-sizing: border-box;
    }

    .category-card-wrapper:has(.selected) .box-content {
        bottom: 12px;
    }

    /* תמונה בתוך הקופסה */
    .box-image {
        max-width: 90%;
        max-height: 90%;
        object-fit: contain;
    }

    /* כפתור X למחיקת תמונה */
    .remove-content-btn {
        position: absolute;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.08s ease-in-out;
        top: -1px;
        right: -1px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        z-index: 10;
        background: none;
        border: none;
        outline: none;
    }

    .category-card-wrapper:has(.selected) .remove-content-btn {
        top: -2px;
        right: -2px;
    }

    .category-card-wrapper:hover .remove-content-btn {
        opacity: 1;
        pointer-events: auto;
    }

    /* כפתור העלאת תמונה */
    .upload-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        background: none;
        border: none;
        cursor: pointer;
        color: black;
        width: 100%;
        height: 100%;
    }
    
    .upload-btn span {
        font-size: 10px;
        text-align: center;
        color: black;
    }

    /* רדיו בטונס מתחת לקופסה */
    .cat-type-radios {
        display: flex;
        gap: 12px;
        direction: ltr;
        margin-top: 8px; /* רווח קבוע ונקי מתחת לקופסה */
        height: 20px;
        z-index: 20; 
        opacity: 0;
        pointer-events: none; /* מונע אינטראקציה כשהם נסתרים */
        transition: opacity 0.15s ease-in-out;
    }

    /* הצגה חלקה ב-Hover */
    .category-card-wrapper:hover .cat-type-radios {
        opacity: 1;
        pointer-events: auto; /* מחזיר את אפשרות ההקשבה להקלקות */
    }
    
    /* כפתורי רדיו: */

    .radio-label {
        display: flex;
        align-items: center;
        gap: 4px;
        cursor: pointer;
        font-size: 14px;
        font-weight: bold;
    }
    
    .radio-label input[type="radio"] {
        appearance: none;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 0.1px solid black;
        background-color: #D9D9D9;
        box-shadow: inset 0 0.2px 0.2px rgba(0, 0, 0, 0.25);
        position: relative;
        cursor: pointer;
        transition: all 0.15s ease-in-out;
    }

    /* העיגול הפנימי כשמסומן */
    .radio-label input[type="radio"]:checked::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: #555;
    }

    .radio-label:has(input:disabled) {
        opacity: 0.3;
        cursor: not-allowed;
    }

    /* שכבת הכיסוי האדומה בזמן hover על הפח */
    .red-overlay {
        position: absolute;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.08s ease-in-out;
        z-index: 10;
    }

    /* קרטון קטן — לא נבחר */
    .category-card-wrapper:not(:has(.selected)) .red-overlay {
        bottom: 0;
        top: 14px;
        left: 50%;
        transform: translateX(-50%);
    }

    /* קרטון גדול — נבחר */
    .category-card-wrapper:has(.selected) .red-overlay {
        top: 0;
        left: 0;
    }

    .category-card-wrapper:has(.delete-btn:hover:not(:disabled)) .red-overlay {
        opacity: 1;
    }
    .category-box.invalid {
        outline: 2.5px solid #FF8080;
        padding: 2px;    
    }

    .upload-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 20;
    }

    .spinner {
        width: 30px;
        height: 30px;
        border: 3px solid #eee;
        border-top: 3px solid #911627;
        border-radius: 50%;
        animation: spin 0.2s linear infinite;
    }


</style>

