                <input type="radio"
                       name="cat-type-@Index"
                       checked="@Cat.IsImage"
                       disabled="@(!string.IsNullOrWhiteSpace(Cat.Content) && !Cat.IsImage)"
                       @onchange="() => { Cat.IsImage = true; OnContentChanged.InvokeAsync(); }"/>


            </label>
        }
        
    </div>
</div>


@if (showImagePopup) // פופ-אפ הגדלת תמונה
{
    <PopUp IsVisible="@showImagePopup"
           Title="הגדלת תמונה"
           ConfirmText=""
           CancelText=""
           OnClose="() => showImagePopup = false"
           OnConfirm="() => showImagePopup = false"
           OnCancel="() => showImagePopup = false"
           ShowButtons="false">
        <img src="uploadedFiles/@Cat.Content" alt="קטגוריה" style="max-width: 100%; max-height: 400px; object-fit: contain;"/>
    </PopUp>
}

@code {
    [Parameter] public CategoryToSave Cat { get; set; } // המידע על הקטגוריה
    [Parameter] public bool IsSelected { get; set; } // כדי להבדיל באיזה קטגוריה המשתמש בחר
    [Parameter] public int Index { get; set; } // מעקב אחרי הקטגוריה 
    [Parameter] public bool CanDelete { get; set; } // האם ניתן למחוק? לא בכל מצב אחפשרי לפי האפיון שלנו
    [Parameter] public EventCallback OnSelect { get; set; } // בזמן בחירת הקטגוריה
    [Parameter] public EventCallback OnDelete { get; set; } // בזמן מחיקת הקטגוריה
    [Parameter] public EventCallback OnImageDelete { get; set; } // בזמן מחיקת תמונה
    [Parameter] public EventCallback<InputFileChangeEventArgs> OnImageUpload { get; set; } // בזמן העלאת תמונה
    [Parameter] public EventCallback OnContentChanged { get; set; } // בזמן שיש שינוי כלשהו בתוכן - משפיע על שמירת שינויים
    // בתוך עמוד עריכה יש פונקציה שמופעלת אחרי כל שינוי של תוכן
    [Parameter] public string CatInputId { get; set; } // שימוש בעיקר בhtml
    [Parameter] public bool IsInvalid { get; set; } = false; // אם יש שגיאה אז נרצה להציג חיווי ויזואלי למשתמש
    [Parameter] public EventCallback OnTextClear { get; set; } // לחיצה על איקס של טקסט
    [Parameter] public bool IsUploading { get; set; } = false; // חיווי בזמן טעינה של תמונה CustomInputSimple inputRef; // רפרנס לקומפוננטת הטקסטc - כדי להשתמש בפונקצייה ניקוי התוכן שיש שם 



    bool isTrashHovered = false; // אם הפח במצב hover - התנהגות ספציפית לפח 
    bool showImagePopup = false; // פופ אפ הגדלת תמונה
    
    void HandleKeyDown(KeyboardEventArgs e) // כדי שיהיה ניתן להשתמש בטאבים
    {
        if (e.Key == "Enter" || e.Key == " ")
            OnSelect.InvokeAsync();
    }
    
}
